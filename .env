# === Server ===
PORT=3000
NODE_ENV=production
SESSION_SECRET=fusion-coaching-super-secret-key-2026

# === PostgreSQL Database ===
DATABASE_URL=postgresql://fusion_user:YOUR_PASSWORD@localhost:5432/fusion_coaching
# For Render: DATABASE_URL will be provided by Render PostgreSQL add-on

# === JWT ===
JWT_SECRET=fusion-jwt-secret-key-2026-secure
JWT_EXPIRES_IN=7d

# === File Upload ===
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# === WhatsApp Cloud API ===
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_whatsapp_access_token
WA_BUSINESS_ACCOUNT_ID=your_business_account_id
WA_API_VERSION=v21.0

# === Fee Reminder ===
FEE_GRACE_PERIOD_DAYS=7
FEE_REMINDER_ENABLED=true
